# Copy this file to .env.local and fill in your Supabase project details.
# The site runs fully without these — it falls back to the local JSON
# fixtures in /data — but a live Supabase database is required if you want
# content to be editable outside of a code deploy. See supabase/schema.sql.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
